{
  "consumer": {
    "name": "ModApiConsumer"
  },
  "interactions": [
    {
      "description": "a request for fish-burger-mod",
      "providerState": "mod fish-burger-mod exists",
      "request": {
        "headers": {
          "Accept": "application/json"
        },
        "method": "GET",
        "path": "/api/mods/fish-burger-mod"
      },
      "response": {
        "body": {
          "assets": {
            "scripts": "/mods/fish-burger/scripts/",
            "styles": "/mods/fish-burger/styles/",
            "templates": "/mods/fish-burger/templates/"
          },
          "description": "Interactive shopping cart with fish burger state machine.",
          "entryPoints": {
            "cart": "/mods/fish-burger/cart",
            "demo": "/mods/fish-burger/demo"
          },
          "id": "fish-burger-mod",
          "modMetadata": {
            "assetLinks": {},
            "pathReplacements": {},
            "spelunkMap": {}
          },
          "name": "Fish Burger Cart",
          "serverUrl": "http://localhost:3004",
          "version": "1.0.0"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "$.body": {
            "match": "type"
          }
        },
        "status": 200
      }
    },
