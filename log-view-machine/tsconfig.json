{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "src/components/CompleteOrderStateMachine.tsx",
    "src/components/OrderControllerStateMachine.tsx",
    "src/components/ServerStateExample.tsx",
    "src/components/StructuralExample.tsx",
    "src/components/TomeIntegration.tsx",
    "src/__tests__",
    "src/App.tsx",
    "src/setupTests.ts"
  ]
}
